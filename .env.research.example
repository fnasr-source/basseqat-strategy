# Copy this file to .env.research.local and fill in only the keys you use.
# Standard automated research expects PERPLEXITY_API_KEY plus FIRECRAWL_API_KEY or TAVILY_API_KEY.
# Presentation image generation uses GOOGLE_GEMINI_API_KEY and must use Nano Banana 2 / Gemini 3.1 Flash Image only.
# Set GOOGLE_GEMINI_IMAGE_MODEL_ID to the current API model ID Google exposes for Nano Banana 2.

FIRECRAWL_API_KEY=
PERPLEXITY_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_IMAGE_MODEL_ID=
