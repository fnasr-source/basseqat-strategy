rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isBreakGlassAdminEmail() {
      return request.auth.token.email in [
        "fnasr@admireworks.com",
        "media@admire8.com"
      ];
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role in ["admin", "superAdmin"] ||
        isBreakGlassAdminEmail() ||
        request.auth.token.email in get(/databases/$(database)/documents/appConfig/adminAccessControl).data.allowedEmails ||
        request.auth.token.email in get(/databases/$(database)/documents/appConfig/main).data.superAdminEmails
      );
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == "superAdmin" ||
        isBreakGlassAdminEmail() ||
        request.auth.token.email in get(/databases/$(database)/documents/appConfig/main).data.superAdminEmails
      );
    }

    function isAdmireworksUser() {
      return isAdmin() && hasUserDoc() && getUserData().userType != "client";
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId && request.resource.data.uid == userId;
      allow update: if request.auth.uid == userId || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /appConfig/{docId} {
      allow read: if isAdmin();
      allow create, update: if isSuperAdmin();
      allow delete: if false;
    }

    match /leads/{leadId} {
      allow create: if true;
      allow get: if true;
      allow list: if isAdmin();
      allow update, delete: if isAdmin();

      match /crmLogs/{logId} {
        allow read, write: if isAdmin();
      }
    }

    match /projectTasks/{taskId} {
      allow read, write: if isAdmin();
    }

    match /campaignFlows/{campaignId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmireworksUser();
    }

    match /adCopies/{copyId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmireworksUser();
    }

    match /conversationState/{docId} {
      allow read, write: if isAdmin();
    }

    match /messageLogs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /crmLogs/{docId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
