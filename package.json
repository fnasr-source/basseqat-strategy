    "research:run:firecrawl": "node scripts/run-research-automation.js firecrawl",
    "research:run:exa": "node scripts/run-research-automation.js exa",
    "research:run:tavily": "node scripts/run-research-automation.js tavily",
    "presentation:build": "npm --prefix apps/presentation run build",
    "presentation:preview": "npm --prefix apps/presentation run preview -- --host",
