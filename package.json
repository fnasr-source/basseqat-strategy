{
  "name": "admireworks-client-os-starter",
  "private": true,
  "version": "0.6.1",
  "scripts": {
    "rename:check": "node scripts/new-client-rename-check.js",
    "firebase:verify:config": "node scripts/verify-config.js",
    "firebase:verify:admin": "node scripts/verify-admin-access.js",
    "firebase:deploy:rules": "node scripts/deploy-rules.js",
    "apphosting:verify": "node scripts/verify-apphosting-build.js",
    "apphosting:rollout": "node scripts/trigger-apphosting-rollout.js",
    "presentation:check": "node scripts/check-presentation.js",
    "presentation:serve": "npm --prefix apps/presentation run dev -- --host",
    "research:check": "node scripts/research-provider-check.js",
    "research:work-order": "node scripts/generate-research-work-order.js",
    "research:firecrawl:verify": "node scripts/verify-firecrawl-access.js",
